#!/usr/bin/env bash
# Strip Cursor co-author trailers so GitHub credits only the repo owner.
MSG_FILE="$1"
if [ -f "$MSG_FILE" ]; then
  sed -i.bak '/^Co-authored-by: Cursor/d' "$MSG_FILE" 2>/dev/null || \
    sed -i '' '/^Co-authored-by: Cursor/d' "$MSG_FILE" 2>/dev/null || true
  rm -f "${MSG_FILE}.bak"
fi
